# Copy this file to .env and fill in your credentials
# The framework reads these via python-dotenv at startup

# Weights & Biases
WANDB_API_KEY=your_wandb_api_key_here
WANDB_ENTITY=your_wandb_username_or_team

# ABIDE data (if downloading programmatically via Nilearn)
ABIDE_DOWNLOAD_DIR=e:/ASD_forever/datasets/raw

# Debug mode (enables DEBUG log level to console)
ASD_DEBUG=0

# MLflow tracking server (leave blank to use local mlruns/)
MLFLOW_TRACKING_URI=

# CUDA device selection (e.g. "0" for first GPU)
CUDA_VISIBLE_DEVICES=0
